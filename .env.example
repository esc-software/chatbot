# Server
HOST=0.0.0.0
PORT=3006

# CORS - comma-separated origins
CORS_ORIGINS=https://esc-software.com,https://www.esc-software.com

# Rate limit
MAX_REQUESTS_PER_MIN=30

# Discord webhook for feedback notifications
FEEDBACK_WEBHOOK_URL=

# Memory
MEMORY_MAXLEN=15

# Queue system (for high concurrency)
QUEUE_WORKERS=2
QUEUE_MAX_SIZE=500

# NLP
VECTOR_SIZE=60
NLP_CONFIDENCE_THRESHOLD=0.55

# Translation (Google Translate API)
ENABLE_TRANSLATION=true
DEFAULT_LANG=pt

# NER
NER_ENABLE_EMAILS=true
NER_ENABLE_PHONES=true
NER_ENABLE_URLS=true
NER_ENABLE_MONEY=true

# Sentiment
SENTIMENT_ENABLED=true

# Spell correction
SPELL_ENABLED=true

# Response diversity (avoid repeating same response)
RESPONSE_DIVERSITY=true

# Path to intents JSON file (customize chatbot responses)
# If not found, falls back to built-in defaults
INTENTS_PATH=config/intents.json

# Redis (optional) — enables persistent storage, distributed queue and rate limiting
# Leave empty to use file-based storage and in-memory queue
REDIS_URL=
